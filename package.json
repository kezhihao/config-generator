{
  "name": "config-generator",
  "version": "1.0.0",
  "description": "配置文件生成 CLI 工具 - 30秒生成正确的配置",
  "type": "module",
  "bin": {
    "config-gen": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "templates/"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "lint": "biome check src/",
    "format": "biome format --write src/"
  },
  "keywords": [
    "config",
    "generator",
    "cli",
    "docker",
    "typescript",
    "eslint",
    "kubernetes",
    "devops",
    "scaffolding",
    "boilerplate",
    "configuration",
    "developer-tools"
  ],
  "author": "Auto Company",
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.3",
    "prompts": "^2.4.2",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/prompts": "^2.4.9",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0",
    "@biomejs/biome": "^2.4.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
